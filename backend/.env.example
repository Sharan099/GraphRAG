# ── Anthropic (required for answer generation) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Neo4j (required for graph traversal path) ──────────────────────
# Use a Neo4j Aura free instance for cloud deploys.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── CORS ───────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API.
# Set to your Vercel URL in production, e.g. https://airgraph.vercel.app
ALLOWED_ORIGINS=*
