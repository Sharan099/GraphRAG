# ── Groq (required for answer generation — Qwen 3 32B) ─────────────
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=qwen/qwen3-32b

# ── Neo4j (required for graph traversal path) ──────────────────────
# Use a Neo4j Aura free instance for cloud deploys.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=airbus2024

# ── LLM tuning (optional) ──────────────────────────────────────────
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ── CORS ───────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API.
# Set to your Vercel URL in production, e.g. https://airgraph.vercel.app
ALLOWED_ORIGINS=*

# ── Offline graph rebuild only (extractor.py / community.py) ───────
# Not needed to serve answers; the graph artefacts are already committed.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
